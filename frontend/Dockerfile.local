FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
# No VITE_API_URL — app calls /api, nginx proxies to backend container
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.local.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
