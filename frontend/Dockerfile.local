FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
# Local Docker: overwrite .env.production with empty value so the app calls /api
# (nginx proxies /api to the backend container). The repo's .env.production targets cloud only.
RUN echo "VITE_API_URL=" > .env.production && npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.local.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
